# Azure AI Foundry Project Configuration
# Required: Your Azure AI Foundry project endpoint
AZURE_AI_PROJECT_ENDPOINT=https://your-project-name.azure-ai.azure.com

# Required: Azure OpenAI model deployment name
MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# Required: Name of the agent to test/evaluate
EXISTING_AGENT_NAME=YourAgentName

# Optional: Specific version of the agent (uses latest if not specified)
# EXISTING_AGENT_VERSION=1

# Alternative naming for Foundry configuration (used by some scripts)
FOUNDRY_PROJECT_ENDPOINT=https://your-project-name.azure-ai.azure.com
FOUNDRY_AGENT_ID=YourAgentName
FOUNDRY_AGENT_VERSION=2

# Azure Monitor Configuration (optional)
# Enables OpenTelemetry traces to be sent to Azure Monitor
# AZURE_MONITOR_CONNECTION_STRING=InstrumentationKey=your-instrumentation-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# OpenTelemetry Configuration (optional)
# Service name for OpenTelemetry traces (default: "openai-agents-app")
OTEL_SERVICE_NAME=openai-agents-app

# Red Team Testing Configuration (optional)
# Number of objectives per risk category (default: 5)
RED_TEAM_NUM_OBJECTIVES=5
